# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/tmp/

/priv/plts/*.plt
/priv/plts/*.plt.hash

.elixir_ls
.idea
*.iml

# Local env - copied from .env.example, may contain real passwords in prod
.env

# Local, never-pushed scratch workspace.
/private/

# DOSBox client bundle artifacts - staged by apps/portal/fetch-start-bundle.sh
# from the em-dosbox-packager and client-bundles repos. init.js and README.md
# in that directory are tracked.
/apps/portal/priv/static/start/dosbox.js
/apps/portal/priv/static/start/dosbox.wasm
/apps/portal/priv/static/start/loader.js
/apps/portal/priv/static/start/*.data
