# Copy this file to `.env` for local dev:
#   cp .env.example .env
#
# Three ways to run the stack:
#   a) Everything local:  manage your own postgres + `iex -S mix phx.server`
#   b) Mix + dockered db: `docker compose up db`, then `DB_PORT=5433 iex -S mix phx.server`
#   c) Full compose dev:  `docker compose up`  (browser to http://localhost)
# Method b/c auto-load docker-compose.override.yaml; method a ignores compose.
#
# Production launch (override.yaml is excluded by being explicit):
#   docker compose -f docker-compose.yaml -f docker-compose.prod.yaml up -d --build
#
# Compose auto-loads `.env` from the project directory. Shell env beats
# `.env`, so the same variables work for both.

DB_NAME=prodigy
DB_USER=prodigy
DB_PASS=prodigy
# DB_HOST: 'db' for method c (compose DNS), 'localhost' for method a/b.
DB_HOST=db
# Host-side mix (method b) reaches the dockered db on :5433 via the
# override mapping. Method a/c don't read this.
# DB_PORT=5433

# Public hostname for this deployment. Read by both the Phoenix app
# (URL generation - mailers, OAuth callbacks) and Caddy (the
# X-Forwarded-Host it pins for the upstream). Leave as localhost for
# dev; set to a real FQDN in prod - it must match wherever your
# OAuth provider's callback URL is registered.
PHX_HOST=localhost

# Phoenix secret_key_base. Generate with:
#   elixir -e 'IO.puts(:crypto.strong_rand_bytes(48) |> Base.encode64())'
# Dev placeholder below is fine for local use. PROD MUST override via shell env.
SECRET_KEY_BASE=LH0YXxKfjfZ/dUnQUQSvzp96Y9Vr7SDCvOYYk6j/fxiSAS0x8Lb+Qlks0eACiv1V

# Enables /dev/mailbox (Swoosh local adapter preview) for auth email flows.
# Leave unset in real prod so emails aren't visible via the web.
PHX_DEV_ROUTES=true

# Ueberauth OAuth providers. Leave a pair unset and that provider's button
# disappears from the login page - no partial configuration, no dummy creds.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# First service-side user created by db-seed (compose only). Defaults
# match seed.sh; override only if you want a different initial credential.
# INIT_USER=AAAA11
# INIT_PASS=SECRET

# DowJones quote sidecar URL. Default works for method c (compose
# internal DNS). For method a/b you'd need to expose the sidecar's port
# and set this to e.g. http://localhost:8000.
# DOWJONES_API_URL=http://dowjones-sidecar:8000

# What is in front of Caddy in the prod overlay. Unset = https/443 (TLS
# terminated upstream: Cloudflare tunnel, ALB, CloudFront). For a TLS-less
# bringup (e.g. the prod overlay on localhost), set http/80 so Phoenix
# issues a non-Secure session cookie (Safari drops Secure cookies over
# plain http, which breaks LiveView with a page-reload loop).
# FORWARDED_PROTO=http
# FORWARDED_PORT=80
